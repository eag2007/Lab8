<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.gui.controller.LoginController"
           styleClass="login-bg">
    <VBox styleClass="login-card" maxWidth="320" maxHeight="460">
        <VBox styleClass="login-header" alignment="CENTER">
            <Label text="Route Manager" styleClass="login-title"/>
            <Label text="Введите данные для входа" styleClass="login-subtitle"/>
        </VBox>

        <VBox styleClass="login-fields" spacing="10">
            <HBox spacing="8">
                <TextField fx:id="hostField" promptText="Хост"
                           text="localhost" styleClass="field" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="portField" promptText="Порт"
                           text="8080" styleClass="field" prefWidth="80"/>
            </HBox>

            <TextField fx:id="loginField" promptText="Логин" styleClass="field" maxWidth="Infinity"/>
            <PasswordField fx:id="passField" promptText="Пароль" styleClass="field" maxWidth="Infinity"/>
            <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" maxWidth="Infinity"/>
        </VBox>

        <VBox styleClass="login-buttons" spacing="8">
            <Button fx:id="loginBtn" text="Войти" onAction="#handleLogin" styleClass="btn-primary"
                    defaultButton="true" maxWidth="Infinity"/>
            <Button fx:id="registerBtn" text="Регистрация" onAction="#handleRegister" styleClass="btn-secondary"
                    maxWidth="Infinity"/>
        </VBox>
    </VBox>
</StackPane>