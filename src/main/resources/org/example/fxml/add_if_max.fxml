<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.gui.controllers.AddIfMaxController" stylesheets="@../css/add_if_max.css" prefWidth="400" prefHeight="650">
    <VBox spacing="8" style="-fx-padding: 20;" prefWidth="360" prefHeight="610">

        <Label text="%add.title" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;" prefHeight="25"/>

        <Label text="%field.name" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="nameField" prefHeight="25"/>

        <Label text="%field.coord_x" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="coordXField" prefHeight="25"/>
        <Label text="%field.coord_y" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="coordYField" prefHeight="25"/>

        <Label text="%field.from_x" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="fromXField" prefHeight="25"/>
        <Label text="%field.from_y" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="fromYField" prefHeight="25"/>
        <Label text="%field.from_z" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="fromZField" prefHeight="25"/>

        <Label text="%field.to_x" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="toXField" prefHeight="25"/>
        <Label text="%field.to_y" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="toYField" prefHeight="25"/>
        <Label text="%field.to_z" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="toZField" prefHeight="25"/>

        <Label text="%field.distance" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="distanceField" prefHeight="25"/>

        <Label text="%field.price" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="priceField" prefHeight="25"/>

        <Label fx:id="errorLabel" style="-fx-text-fill: red; -fx-wrap-text: true; -fx-font-size: 10;" prefHeight="50"/>

        <HBox spacing="10" alignment="CENTER" prefHeight="35">
            <Button text="%add.btn.add" onAction="#onAddIfMaxClick" styleClass="btn-primary" prefWidth="120" prefHeight="30"/>
            <Button text="%dialog.cancel" onAction="#onCancelClick" styleClass="btn-secondary" prefWidth="120" prefHeight="30"/>
        </HBox>

    </VBox>
</StackPane>
