<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.gui.controllers.AverageOfDistanceController"
           stylesheets="@../css/average_of_distance.css"
           prefWidth="400" prefHeight="250">

    <VBox spacing="15" style="-fx-padding: 25;" prefWidth="360" prefHeight="230">

        <Label text="СРЕДНЕЕ ЗНАЧЕНИЕ DISTANCE"
               style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"
               prefHeight="25"/>

        <Label text="Среднее значение distance всех маршрутов:"
               style="-fx-font-size: 12; -fx-wrap-text: true; -fx-text-fill: #888888;"
               prefHeight="32"/>

        <Label fx:id="averageValue"
               style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #5865f2; -fx-alignment: center;"
               prefHeight="50" alignment="CENTER"/>

        <Label fx:id="errorLabel" styleClass="error-label" prefHeight="35"/>

        <HBox spacing="10" alignment="CENTER" prefHeight="40">
            <Button text="ЗАКРЫТЬ" onAction="#onCloseClick" styleClass="btn-secondary" prefWidth="120" prefHeight="35"/>
        </HBox>

    </VBox>
</StackPane>