<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.gui.controllers.InfoController"
      spacing="10"
      style="-fx-padding: 20; -fx-background-color: #2b2b2b;"
      prefWidth="400" prefHeight="250">

    <Label text="Информация о коллекции"
           style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;"/>

    <TextArea fx:id="infoText"
              editable="false"
              wrapText="true"
              VBox.vgrow="ALWAYS"
              style="-fx-font-family: monospace; -fx-font-size: 13;"/>

    <Button text="Закрыть"
            onAction="#onCloseClick"
            prefWidth="100"
            style="-fx-background-color: #ff4444; -fx-text-fill: white;"/>
</VBox>