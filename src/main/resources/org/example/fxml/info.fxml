<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<VBox stylesheets="@../css/info.css" styleClass="info-root" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.gui.controllers.InfoController" spacing="0" prefWidth="550" prefHeight="400">

    <HBox styleClass="info-header" alignment="CENTER_LEFT" prefHeight="55">
        <Rectangle styleClass="info-header-rect" width="3" height="16" arcWidth="2" arcHeight="2"/>
        <Label styleClass="info-header-title" text="Информация о коллекции"/>
    </HBox>

    <TextArea styleClass="info-textarea" fx:id="infoText" editable="false" wrapText="true" VBox.vgrow="ALWAYS"/>

    <HBox styleClass="info-footer" alignment="CENTER_RIGHT" prefHeight="55">
        <Button styleClass="info-close-btn" onAction="#onCloseClick" text="ЗАКРЫТЬ"/>
    </HBox>
</VBox>