<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.gui.controllers.AddController" stylesheets="@../css/add.css" prefWidth="400" prefHeight="650">
    <VBox spacing="8" style="-fx-padding: 20;" prefWidth="360" prefHeight="610">

        <Label text="ДОБАВЛЕНИЕ МАРШРУТА" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;" prefHeight="25"/>

        <Label text="NAME:" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="nameField" prefHeight="25"/>

        <Label text="Coordinates X:" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="coordXField" prefHeight="25"/>
        <Label text="Coordinates Y:" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="coordYField" prefHeight="25"/>

        <Label text="From X:" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="fromXField" prefHeight="25"/>
        <Label text="From Y:" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="fromYField" prefHeight="25"/>
        <Label text="From Z:" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="fromZField" prefHeight="25"/>

        <Label text="To X:" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="toXField" prefHeight="25"/>
        <Label text="To Y:" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="toYField" prefHeight="25"/>
        <Label text="To Z:" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="toZField" prefHeight="25"/>

        <Label text="Distance:" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="distanceField" prefHeight="25"/>

        <Label text="Price:" prefHeight="15" style="-fx-font-size: 11;"/>
        <TextField fx:id="priceField" prefHeight="25"/>

        <Label fx:id="errorLabel" style="-fx-text-fill: red; -fx-wrap-text: true; -fx-font-size: 10;" prefHeight="50"/>

        <HBox spacing="10" alignment="CENTER" prefHeight="35">
            <Button text="ДОБАВИТЬ" onAction="#onAddClick" styleClass="btn-primary" prefWidth="120" prefHeight="30"/>
            <Button text="ОТМЕНА" onAction="#onCancelClick" styleClass="btn-secondary" prefWidth="120" prefHeight="30"/>
        </HBox>

    </VBox>
</StackPane>