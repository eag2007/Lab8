<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.gui.controllers.FilterLessThanDistanceController"
           stylesheets="@../css/filter_less_than_distance.css"
           prefWidth="450" prefHeight="320">

    <VBox spacing="12" style="-fx-padding: 20;" prefWidth="410" prefHeight="300">

        <Label text="%filter.dist.title"
               style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"
               prefHeight="25"/>

        <Label text="%filter.dist.desc"
               style="-fx-font-size: 12; -fx-wrap-text: true; -fx-text-fill: #888888;"
               prefHeight="40"/>

        <Label text="%filter.dist.label" prefHeight="15" style="-fx-font-size: 12; -fx-text-fill: #888888;"/>
        <TextField fx:id="distanceField" prefHeight="35"/>

        <Label fx:id="errorLabel" styleClass="error-label" prefHeight="35"/>

        <HBox spacing="10" alignment="CENTER" prefHeight="40">
            <Button text="%filter.dist.btn" onAction="#onFilterClick" styleClass="btn-primary" prefWidth="120" prefHeight="35"/>
            <Button text="%dialog.cancel" onAction="#onCancelClick" styleClass="btn-secondary" prefWidth="120" prefHeight="35"/>
        </HBox>

    </VBox>
</StackPane>
