<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane stylesheets="@../css/register.css" styleClass="register-root" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.gui.controllers.RegisterController">

    <VBox styleClass="register-box" fx:id="registerBox" maxWidth="500" maxHeight="650" prefWidth="500" prefHeight="650" alignment="CENTER" spacing="0">

        <HBox style="-fx-padding: 12 12 0 0;" alignment="TOP_RIGHT">
            <ComboBox fx:id="langCombo" onAction="#onLangChange" prefWidth="80"/>
        </HBox>

        <VBox styleClass="register-header" alignment="CENTER">
            <Label styleClass="register-label" text="ROUTE DB"/>
            <Label styleClass="register-title" fx:id="titleLabel" text="Регистрация"/>
            <Label styleClass="register-subtitle" fx:id="subtitleLabel" text="Создайте новый аккаунт"/>
        </VBox>

        <VBox styleClass="register-fields">
            <TextField styleClass="register-field" fx:id="regLoginField" promptText="Логин" prefHeight="72"/>
            <PasswordField styleClass="register-field" fx:id="regPasswordField" promptText="Пароль" prefHeight="72"/>
            <PasswordField styleClass="register-field" fx:id="confirmPasswordField" promptText="Подтвердите пароль" prefHeight="72"/>
            <Label styleClass="register-error" fx:id="errorLabel" text=""/>
        </VBox>

        <VBox styleClass="register-buttons" alignment="CENTER">
            <Button styleClass="register-btn" fx:id="registerBtn" onAction="#onRegisterClick" prefHeight="72" prefWidth="320" text="ЗАРЕГИСТРИРОВАТЬСЯ"/>
            <Hyperlink styleClass="register-hyperlink" fx:id="loginLink" onAction="#onLoginLinkClick" text="Уже есть аккаунт? Войти"/>
            <ProgressIndicator fx:id="loadingSpinner" visible="false" prefWidth="40" prefHeight="40" style="-fx-progress-color: #5865f2;"/>
        </VBox>
    </VBox>
</StackPane>