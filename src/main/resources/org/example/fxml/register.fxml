<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<StackPane stylesheets="@../css/register.css" styleClass="register-root" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.gui.controllers.RegisterController">

    <Rectangle styleClass="register-accent-line" width="4" height="290" translateX="-232" translateY="0" arcWidth="4" arcHeight="4"/>

    <VBox styleClass="register-box" fx:id="registerBox" alignment="CENTER" maxWidth="468" maxHeight="520" prefWidth="468" prefHeight="520" spacing="0">

        <VBox styleClass="register-header" alignment="CENTER">
            <Label styleClass="register-label" text="ROUTE DB"/>
            <Label styleClass="register-title" text="Регистрация"/>
            <Label styleClass="register-subtitle" text="Создайте новый аккаунт"/>
        </VBox>

        <VBox styleClass="register-fields">
            <TextField styleClass="register-field" fx:id="regLoginField" promptText="Логин" prefHeight="48"/>
            <PasswordField styleClass="register-field" fx:id="regPasswordField" promptText="Пароль" prefHeight="48"/>
            <PasswordField styleClass="register-field" fx:id="confirmPasswordField" promptText="Подтвердите пароль" prefHeight="48"/>
        </VBox>

        <VBox styleClass="register-buttons" alignment="CENTER">
            <Button styleClass="register-btn" onAction="#onRegisterClick" prefHeight="48" prefWidth="388" text="ЗАРЕГИСТРИРОВАТЬСЯ"/>
            <Hyperlink styleClass="register-hyperlink" onAction="#onLoginLinkClick" text="Уже есть аккаунт? Войти"/>
        </VBox>
    </VBox>
</StackPane>