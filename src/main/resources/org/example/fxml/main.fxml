<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.control.TextField?>

<StackPane stylesheets="@../css/main.css" styleClass="main-root" fx:id="mainRoot" xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.gui.controllers.MainController">

    <VBox prefHeight="800" prefWidth="1200">

        <HBox styleClass="main-topbar" alignment="CENTER_LEFT" prefHeight="52">
            <Label styleClass="logo" text="ROUTE DB"/>
            <Rectangle styleClass="separator" width="1" height="20"/>
            <Label styleClass="title" fx:id="mainTitle" text="Управление коллекцией маршрутов"/>
        </HBox>

        <HBox styleClass="main-toolbar" alignment="CENTER_LEFT" prefHeight="52">
            <Button styleClass="btn-primary" fx:id="showBtn" onAction="#onShowClick" text="↺  SHOW"/>
            <Button styleClass="btn-secondary" fx:id="infoBtn" onAction="#onInfoClick" text="INFO"/>
            <Rectangle styleClass="toolbar-separator" width="1" height="24"/>
            <Button styleClass="btn-green" fx:id="addBtn" text="ADD" onAction="#onAddClick"/>
            <Button styleClass="btn-green" fx:id="addIfMaxBtn" text="ADD IF MAX" onAction="#onAddIfMaxClick"/>
            <Button styleClass="btn-green" fx:id="updateBtn" text="UPDATE" onAction="#onUpdateClick"/>
            <Rectangle styleClass="toolbar-separator" width="1" height="24"/>
            <Button styleClass="btn-danger" fx:id="removeIdBtn" text="REMOVE ID" onAction="#onRemoveByIdClick"/>
            <Button styleClass="btn-danger" fx:id="removeFirstBtn" text="REMOVE FIRST" onAction="#onRemoveFirstClick"/>
            <Button styleClass="btn-danger" fx:id="removeAllDistBtn" text="REMOVE ALL DIST" onAction="#onRemoveAllDistClick"/>
            <Button styleClass="btn-danger" fx:id="clearBtn" text="CLEAR" onAction="#onClearClick"/>
            <Rectangle styleClass="toolbar-separator" width="1" height="24"/>
            <Button styleClass="btn-secondary" fx:id="filterDistBtn" text="FILTER DIST" onAction="#onFilterDistClick"/>
            <Button styleClass="btn-secondary" fx:id="avgDistBtn" text="AVERAGE DIST" onAction="#onAverageDistanceClick"/>
            <Button styleClass="btn-secondary" fx:id="execScriptBtn" text="EXECUTE SCRIPT" onAction="#onExecuteScriptClick"/>
            <Button styleClass="btn-secondary" fx:id="helpBtn" text="HELP" onAction="#onHelpClick"/>
            <Button styleClass="btn-secondary" fx:id="historyBtn" text="HISTORY" onAction="#onHistoryClick"/>
            <Label fx:id="userLoginLabel" text="не авторизован"
                   style="-fx-padding: 8 15; -fx-background-radius: 20; -fx-background-color: #5865f2; -fx-text-fill: white; -fx-font-family: 'Courier New'; -fx-font-size: 13; -fx-font-weight: bold;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button styleClass="btn-secondary" fx:id="logoutBtn" onAction="#onLogoutClick" text="ВЫЙТИ"/>
        </HBox>

        <TabPane fx:id="tabPane" VBox.vgrow="ALWAYS"
                 style="-fx-background-color: #1a1a1a; -fx-tab-min-height: 40; -fx-tab-max-height: 40;">
            <Tab fx:id="tableTab" text="ТАБЛИЦА" closable="false">
                <HBox VBox.vgrow="ALWAYS" style="-fx-padding: 20 0 20 40; -fx-background-color: #1a1a1a;">
                    <TableView styleClass="main-table" fx:id="routeTable" HBox.hgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colId" text="ID" prefWidth="60" minWidth="50"/>
                            <TableColumn fx:id="colName" text="Name" prefWidth="140" minWidth="100"/>
                            <TableColumn fx:id="colCoordX" text="Coord X" prefWidth="80" minWidth="60"/>
                            <TableColumn fx:id="colCoordY" text="Coord Y" prefWidth="80" minWidth="60"/>
                            <TableColumn fx:id="colFromX" text="From X" prefWidth="80" minWidth="60"/>
                            <TableColumn fx:id="colFromY" text="From Y" prefWidth="80" minWidth="60"/>
                            <TableColumn fx:id="colFromZ" text="From Z" prefWidth="80" minWidth="60"/>
                            <TableColumn fx:id="colToX" text="To X" prefWidth="80" minWidth="60"/>
                            <TableColumn fx:id="colToY" text="To Y" prefWidth="80" minWidth="60"/>
                            <TableColumn fx:id="colToZ" text="To Z" prefWidth="80" minWidth="60"/>
                            <TableColumn fx:id="colDistance" text="Distance" prefWidth="80" minWidth="60"/>
                            <TableColumn fx:id="colPrice" text="Price" prefWidth="80" minWidth="60"/>
                            <TableColumn fx:id="colAuthor" text="Author" prefWidth="120" minWidth="80"/>
                            <TableColumn fx:id="colDate" text="Date" prefWidth="160" minWidth="120"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                        <placeholder>
                            <Label fx:id="tablePlaceholder" styleClass="main-placeholder" text="Нет данных — нажмите SHOW для загрузки"/>
                        </placeholder>
                    </TableView>

                    <HBox style="-fx-padding: 0 40 0 0;">
                        <VBox styleClass="info-panel" fx:id="infoPanel" prefWidth="300" minWidth="250" maxWidth="350">
                            <Label styleClass="info-panel-title" fx:id="infoPanelTitle" text="ДЕТАЛИ МАРШРУТА"/>
                            <VBox styleClass="info-panel-content" fx:id="infoPanelContent" spacing="12">

                                <Label text="ID:"/>
                                <Label fx:id="routeIdLabel" text=""/>

                                <Label text="NAME:"/>
                                <TextField fx:id="routeNameField"/>

                                <Label text="Coordinates X:"/>
                                <TextField fx:id="routeCoordXField"/>
                                <Label text="Coordinates Y:"/>
                                <TextField fx:id="routeCoordYField"/>

                                <Label text="From X:"/>
                                <TextField fx:id="routeFromXField"/>
                                <Label text="From Y:"/>
                                <TextField fx:id="routeFromYField"/>
                                <Label text="From Z:"/>
                                <TextField fx:id="routeFromZField"/>

                                <Label text="To X:"/>
                                <TextField fx:id="routeToXField"/>
                                <Label text="To Y:"/>
                                <TextField fx:id="routeToYField"/>
                                <Label text="To Z:"/>
                                <TextField fx:id="routeToZField"/>

                                <Label text="Distance:"/>
                                <TextField fx:id="routeDistanceField"/>

                                <Label text="Price:"/>
                                <TextField fx:id="routePriceField"/>

                                <Label text="Author:"/>
                                <Label fx:id="routeAuthorLabel"/>

                                <Label text="Creation Date:"/>
                                <Label fx:id="routeDateLabel"/>

                            </VBox>
                        </VBox>
                    </HBox>
                </HBox>
            </Tab>
            <Tab fx:id="vizTab" text="ВИЗУАЛИЗАЦИЯ" closable="false">
                <Pane fx:id="vizPane" style="-fx-background-color: #1a1a1a;"/>
            </Tab>
        </TabPane>

        <HBox styleClass="main-statusbar" alignment="CENTER_LEFT" prefHeight="28">
            <Label fx:id="statusLabel" styleClass="status-connected" text="●  Подключено"/>
            <Label styleClass="status-host" text="localhost:8080"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="langCombo" onAction="#onLangChange" prefWidth="80"
                      style="-fx-background-color: #111111; -fx-border-color: #2a2a2a; -fx-border-width: 1; -fx-font-family: 'Courier New'; -fx-font-size: 12;"/>
        </HBox>
    </VBox>
</StackPane>