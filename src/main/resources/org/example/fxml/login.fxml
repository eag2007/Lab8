<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane stylesheets="@../css/login.css" styleClass="login-root" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.gui.controllers.LoginController">

    <VBox styleClass="login-box" fx:id="loginBox" maxWidth="500" maxHeight="550" prefWidth="500" prefHeight="550" alignment="CENTER" spacing="0">

        <HBox style="-fx-padding: 12 12 0 0;" alignment="TOP_RIGHT">
            <ComboBox fx:id="langCombo" onAction="#onLangChange" prefWidth="80"/>
        </HBox>

        <VBox styleClass="login-header" alignment="CENTER">
            <Label styleClass="login-label" text="ROUTE DB"/>
            <Label styleClass="login-title" fx:id="titleLabel" text="Вход в систему"/>
            <Label styleClass="login-subtitle" fx:id="subtitleLabel" text="Введите учётные данные"/>
        </VBox>

        <VBox styleClass="login-fields">
            <TextField styleClass="login-field" fx:id="loginField" promptText="Логин" prefHeight="72"/>
            <PasswordField styleClass="login-field" fx:id="passwordField" promptText="Пароль" prefHeight="72"/>
            <Label styleClass="login-error" fx:id="errorLabel" text=""/>
        </VBox>

        <VBox styleClass="login-buttons" alignment="CENTER">
            <Button styleClass="login-btn" fx:id="loginBtn" onAction="#onLoginClick" prefHeight="72" prefWidth="320" text="ВОЙТИ"/>
            <Hyperlink styleClass="login-hyperlink" fx:id="registerLink" onAction="#onRegisterLinkClick" text="Нет аккаунта? Зарегистрироваться"/>
            <ProgressIndicator fx:id="loadingSpinner" visible="false" prefWidth="40" prefHeight="40" style="-fx-progress-color: #5865f2;"/>
        </VBox>
    </VBox>
</StackPane>