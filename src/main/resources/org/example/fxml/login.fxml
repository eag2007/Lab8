<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane style="-fx-background-color: #2b2b2b;" xmlns="http://javafx.com/javafx/25.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.gui.controllers.LoginController">

    <VBox fx:id="loginBox" alignment="CENTER" maxHeight="450.0" maxWidth="450.0" prefHeight="450.0" prefWidth="450.0" spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-border-radius: 5; -fx-background-radius: 5;">

        <Label alignment="CENTER" contentDisplay="CENTER" prefHeight="51.0" prefWidth="81.0" style="-fx-font-size: 20; -fx-font-weight: bold;" text="Вход">
         <font>
            <Font size="20.0" />
         </font></Label>

        <TextField fx:id="loginField" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="60.0" prefWidth="400.0" promptText="Логин">
         <font>
            <Font size="24.0" />
         </font></TextField>
        <PasswordField fx:id="passwordField" maxWidth="-Infinity" prefHeight="63.0" prefWidth="400.0" promptText="Пароль">
         <font>
            <Font size="24.0" />
         </font></PasswordField>
        <Button onAction="#onLoginClick" prefHeight="43.0" prefWidth="220.0" text="Войти">
         <font>
            <Font size="20.0" />
         </font></Button>

        <Hyperlink alignment="CENTER" onAction="#onRegisterLinkClick" prefHeight="33.0" prefWidth="302.0" style="-fx-text-fill: #2b6f9e;" text="Нет аккаунта? Зарегистрироваться">
         <font>
            <Font size="15.0" />
         </font></Hyperlink>

    </VBox>

</StackPane>
