<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<StackPane stylesheets="@../css/login.css" styleClass="login-root" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.gui.controllers.LoginController">

    <Rectangle styleClass="login-accent-line" width="4" height="260" translateX="-232" translateY="0" arcWidth="4" arcHeight="4"/>

    <ComboBox fx:id="langCombo" onAction="#onLangChange" prefWidth="80"
              StackPane.alignment="TOP_RIGHT" translateX="-20" translateY="20"
              style="-fx-background-color: #161616; -fx-border-color: #2a2a2a; -fx-border-width: 1; -fx-font-family: 'Courier New'; -fx-font-size: 12;"/>

    <VBox styleClass="login-box" fx:id="loginBox" maxWidth="468" maxHeight="460" prefWidth="468" prefHeight="460" alignment="CENTER" spacing="0">

        <VBox styleClass="login-header" alignment="CENTER">
            <Label styleClass="login-label" text="ROUTE DB"/>
            <Label styleClass="login-title" fx:id="titleLabel" text="Вход в систему"/>
            <Label styleClass="login-subtitle" fx:id="subtitleLabel" text="Введите учётные данные"/>
        </VBox>

        <VBox styleClass="login-fields">
            <TextField styleClass="login-field" fx:id="loginField" promptText="Логин" prefHeight="48"/>
            <PasswordField styleClass="login-field" fx:id="passwordField" promptText="Пароль" prefHeight="48"/>
            <Label styleClass="login-error" fx:id="errorLabel" text=""/>
        </VBox>

        <VBox styleClass="login-buttons" alignment="CENTER">
            <Button styleClass="login-btn" fx:id="loginBtn" onAction="#onLoginClick" prefHeight="48" prefWidth="388" text="ВОЙТИ"/>
            <Hyperlink styleClass="login-hyperlink" fx:id="registerLink" onAction="#onRegisterLinkClick" text="Нет аккаунта? Зарегистрироваться"/>
            <ProgressIndicator fx:id="loadingSpinner" visible="false" prefWidth="36" prefHeight="36" style="-fx-progress-color: #5865f2;"/>
        </VBox>
    </VBox>
</StackPane>
